#!/bin/sh
# commit-msg hook — validates messages against AGENTS.md convention:
#   <emoji> <type>[(scope)][!]: <description>

COMMIT_MSG_FILE="$1"
FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE")

# Skip commits generated by git itself
case "$FIRST_LINE" in
  "Merge branch "* | "Merge pull request "* | "Merge remote-tracking "* | \
  "Revert \""* | "fixup! "* | "squash! "*)
    exit 0 ;;
esac

# ANSI colours when stderr is a terminal
if [ -t 2 ]; then
  RED='\033[0;31m'; YELLOW='\033[0;33m'; CYAN='\033[0;36m'
  BOLD='\033[1m';   NC='\033[0m'
else
  RED=''; YELLOW=''; CYAN=''; BOLD=''; NC=''
fi

_err()  { printf "%b[commit-msg]%b %s\n"   "${RED}${BOLD}" "$NC" "$1" >&2; }
_hint() { printf "%bHint:%b          %s\n" "$YELLOW"        "$NC" "$1" >&2; }
_info() { printf "%b%s:%b             %s\n" "$CYAN" "$1" "$NC" "$2" >&2; }

VALID_TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# ── 1. Overall format ─────────────────────────────────────────────────────────
# Must match:  <emoji> <type>[(scope)][!]: <description>
if ! printf '%s' "$FIRST_LINE" | grep -qP \
    "^\S+\s+(${VALID_TYPES})(\([^)]+\))?(!)?:\s+\S"; then
  _err  "Commit message does not match the required format."
  _hint "<emoji> <type>[(scope)][!]: <description>"
  _info "Example" "✨ feat(gallery): add artwork forking flow"
  _info "Yours  " "$FIRST_LINE"
  printf '\n' >&2
  exit 1
fi

# ── 2. Extract emoji and type ─────────────────────────────────────────────────
EMOJI=$(printf '%s' "$FIRST_LINE" | grep -oP '^\S+')
TYPE=$(printf  '%s' "$FIRST_LINE" | grep -oP "(?<=\s)(${VALID_TYPES})(?=[\(!:])")

# ── 3. Validate emoji ↔ type pairing ─────────────────────────────────────────
case "$TYPE" in
  feat)     EXPECTED="✨"  ;;
  fix)      EXPECTED="🐛"  ;;
  docs)     EXPECTED="📝"  ;;
  style)    EXPECTED="💄"  ;;
  refactor) EXPECTED="♻️"  ;;
  perf)     EXPECTED="⚡"  ;;
  test)     EXPECTED="✅"  ;;
  build)    EXPECTED="🏗️" ;;
  ci)       EXPECTED="👷"  ;;
  chore)    EXPECTED="🧹"  ;;
  revert)   EXPECTED="⏪"  ;;
esac

if [ "$EMOJI" != "$EXPECTED" ]; then
  _err  "Emoji does not match type '${TYPE}'."
  _hint "Use '${EXPECTED}' for '${TYPE}', got '${EMOJI}'"
  printf '\n' >&2
  exit 1
fi

# ── 4. Description must not end with a period ─────────────────────────────────
DESCRIPTION=$(printf '%s' "$FIRST_LINE" | grep -oP '(?<=:\s).+$')
case "$DESCRIPTION" in
  *.)
    _err  "Description must not end with a period."
    _hint "Remove the trailing '.' from: ${DESCRIPTION}"
    printf '\n' >&2
    exit 1 ;;
esac

exit 0
