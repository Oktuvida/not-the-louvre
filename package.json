{
	"name": "not-the-louvre-workspace",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"workspaces": ["apps/*"],
	"scripts": {
		"dev": "bun run --filter @not-the-louvre/web dev",
		"build": "bun run --filter @not-the-louvre/web build",
		"preview": "bun run --filter @not-the-louvre/web preview",
		"prepare": "bun run --filter @not-the-louvre/web prepare",
		"check": "bun run --filter @not-the-louvre/web check",
		"check:watch": "bun run --filter @not-the-louvre/web check:watch",
		"lint": "bun run --filter @not-the-louvre/web lint",
		"format": "bun run --filter @not-the-louvre/web format",
		"test:unit": "bun run --filter @not-the-louvre/web test:unit",
		"test": "bun run --filter @not-the-louvre/web test",
		"test:e2e": "bun run --filter @not-the-louvre/web test:e2e",
		"db:start": "sh -c '[ -f .env.supabase ] || cp .env.supabase.example .env.supabase; docker compose --env-file .env.supabase up -d'",
		"db:stop": "sh -c '[ -f .env.supabase ] || cp .env.supabase.example .env.supabase; docker compose --env-file .env.supabase down'",
		"db:reset": "sh -c '[ -f .env.supabase ] || cp .env.supabase.example .env.supabase; docker compose --env-file .env.supabase down -v --remove-orphans && docker compose --env-file .env.supabase up -d --wait && bun run --filter @not-the-louvre/web db:migrate'",
		"db:push": "bun run --filter @not-the-louvre/web db:push",
		"db:generate": "bun run --filter @not-the-louvre/web db:generate",
		"db:migrate": "bun run --filter @not-the-louvre/web db:migrate",
		"db:studio": "bun run --filter @not-the-louvre/web db:studio",
		"auth:schema": "bun run --filter @not-the-louvre/web auth:schema"
	}
}
