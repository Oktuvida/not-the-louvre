# Drizzle
DATABASE_URL="postgres://postgres:mysecretpassword@localhost:5432/postgres"

# In production set this to the public HTTPS origin served by Caddy, e.g. https://app.example.com
ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Supabase public browser config
# Canonical production names are SUPABASE_PUBLIC_URL and SUPABASE_ANON_KEY.
# Current server loads also tolerate PUBLIC_SUPABASE_URL, PUBLIC_SUPABASE_ANON_KEY, and ANON_KEY as transitional aliases.
SUPABASE_PUBLIC_URL="http://localhost:8000"
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Server-only Supabase storage config
# In production set exactly one of SUPABASE_SECRET_KEY or SERVICE_ROLE_KEY.
# These secrets must never be serialized into browser payloads.
SUPABASE_SECRET_KEY=""
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# Server-only realtime token signing secret.
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Runtime defaults for VPS deploys are HOST=127.0.0.1 and PORT=3000, injected by /etc/not-the-louvre/not-the-louvre.env.
# Avatar uploads reuse the same bucket unless you change the server storage config
ARTWORK_STORAGE_BUCKET="artworks"
