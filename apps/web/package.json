{
	"name": "@not-the-louvre/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "bun run scripts/build-production.ts",
		"build:e2e": "vite build",
		"model:transform:studio": "bun run scripts/transform-studio-model.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && tsc --noEmit -p ./tsconfig.json && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "bun run test:unit:server && bun run test:unit:client",
		"test:unit:server": "node scripts/run-vitest-project.mjs --project server",
		"test:unit:client": "node scripts/run-vitest-project.mjs --project client --allow-hang-after-pass",
		"test": "bun run test:unit && bun run test:e2e",
		"test:e2e": "playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "bun run scripts/seed-artworks.ts",
		"db:reset": "cd ../.. && bun run db:reset",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes && bun run scripts/generate-auth-schema.ts"
	},
	"dependencies": {
		"@2toad/profanity": "^3.3.0",
		"@supabase/supabase-js": "^2.100.1",
		"@threlte/core": "^8.5.2",
		"@threlte/extras": "^9.13.0",
		"better-auth": "~1.4.21",
		"drizzle-orm": "^0.45.1",
		"fflate": "^0.8.2",
		"gsap": "^3.14.2",
		"jose": "^6.2.2",
		"lucide-svelte": "^1.0.1",
		"postgres": "^3.4.8",
		"sharp": "^0.34.5",
		"three": "^0.183.2",
		"virtua": "^0.49.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.3.2",
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@types/three": "^0.183.1",
		"@vitest/browser-playwright": "^4.1.0",
		"drizzle-kit": "^0.31.8",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	}
}
